u0435\u043d\u0442 1-\u0433\u043e \u043a\u0443\u0440\u0441\u0430 \u0431\u0430\u043a\u0430\u043b\u0430\u0432\u0440\u0438\u0430\u0442\u0430 \u0423\u043d\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442 \u0418\u0422\u041c\u041e \u0424\u0430\u043a\u0443\u043b\u044c\u0442\u0435\u0442 \u043f\u0440\u043e\u0433\u0440\u0430\u043c\u043c\u043d\u043e\u0439 \u0438\u043d\u0436\u0435\u043d\u0435\u0440\u0438\u0438 \u0438 \u043a\u043e\u043c\u043f\u044c\u044e\u0442\u0435\u0440\u043d\u043e\u0439 \u0442\u0435\u0445\u043d\u0438\u043a\u0438 (\u041f\u0418\u0438\u041a\u0422) \u041d\u0430\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u0435: \u041d\u0435\u0439\u0440\u043e\u0442\u0435\u0445\u043d\u043e\u043b\u043e\u0433\u0438\u0438 \u0438 \u043f\u0440\u043e\u0433\u0440\u0430\u043c\u043c\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435 \u041f\u0435\u0440\u0438\u043e\u0434 \u043e\u0431\u0443\u0447\u0435\u043d\u0438\u044f: 2025 \u2014 2029 \u041e \u043c\u043e\u0435\u043c \u043f\u0443\u0442\u0438 \u0421 \u0434\u0435\u0442\u0441\u0442\u0432\u0430 \u043e\u0447\u0435\u043d\u044c \u0441\u0438\u043b\u044c\u043d\u043e \u043f\u0440\u0438\u0441\u0442\u0440\u0430\u0441\u0442\u0438\u043b\u0441\u044f \u043a \u043a\u043e\u043c\u043f\u044c\u044e\u0442\u0435\u0440\u0443, \u0438\u0433\u0440\u0430\u043b \u0432 \u0438\u0433\u0440\u044b. \u041d\u043e \u043a\u043e\u0433\u0434\u0430 \u043f\u0440\u0438\u0448\u043b\u043e \u043e\u0441\u043e\u0437\u043d\u0430\u043d\u0438\u0435 \u0442\u043e\u0433\u043e, \u0447\u0442\u043e \u043d\u0430 \u043a\u043e\u043c\u043f\u044c\u044e\u0442\u0435\u0440\u0435 \u043c\u043e\u0436\u043d\u043e \u043d\u0435 \u0442\u043e\u043b\u044c\u043a\u043e \u0438\u0433\u0440\u0430\u0442\u044c, \u044f \u0443\u0432\u043b\u0435\u043a\u0441\u044f \u043f\u0440\u043e\u0433\u0440\u0430\u043c\u043c\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435\u043c, \u0430 \u0442\u0430\u043a \u0436\u0435 \u043c\u0430\u0442\u0435\u043c\u0430\u0442\u0438\u043a\u043e\u0439 \u0438 \u043c\u0430\u0448\u0438\u043d\u043d\u044b\u043c \u043e\u0431\u0443\u0447\u0435\u043d\u0438\u0435\u043c, \u0440\u0430\u0437\u0440\u0430\u0431\u043e\u0442\u043a\u043e\u0439 \u0438\u0433\u0440. \u0418 \u0432\u043e\u0442 \u044f \u0437\u0434\u0435\u0441\u044c :) \u0421\u0442\u0435\u043a \u0442\u0435\u0445\u043d\u043e\u043b\u043e\u0433\u0438\u0439 \u042f\u0437\u044b\u043a \u0423\u0440\u043e\u0432\u0435\u043d\u044c Python \u041f\u0440\u043e\u0434\u0432\u0438\u043d\u0443\u0442\u044b\u0439 C++ \u0421\u0440\u0435\u0434\u043d\u0438\u0439 C# \u0421\u0440\u0435\u0434\u043d\u0438\u0439 Java \u0411\u0430\u0437\u043e\u0432\u044b\u0439 \u041c\u043e\u0438 \u0438\u043d\u0442\u0435\u0440\u0435\u0441\u044b \u0418\u0441\u043a\u0443\u0441\u0441\u0442\u0432\u0435\u043d\u043d\u044b\u0439 \u0438\u043d\u0442\u0435\u043b\u043b\u0435\u043a\u0442, \u043c\u0430\u0448\u0438\u043d\u043d\u043e\u0435 \u043e\u0431\u0443\u0447\u043d\u0438\u0435 \u0420\u0430\u0437\u0440\u0430\u0431\u043e\u0442\u043a\u0430 \u0438\u0433\u0440 \u041c\u0430\u0442\u0435\u043c\u0430\u0442\u0438\u043a\u0430 (\u043e\u043b\u0438\u043c\u043f\u0438\u0430\u0434\u043d\u0430\u044f) \u0428\u0430\u0445\u043c\u0430\u0442\u044b \u00ab\u041a\u043e\u0434 \u2014 \u044d\u0442\u043e \u043b\u0438\u0448\u044c \u043e\u0442\u0440\u0430\u0436\u0435\u043d\u0438\u0435 \u043c\u044b\u0441\u043b\u0438. \u041d\u0430\u0441\u0442\u043e\u044f\u0449\u0430\u044f \u043c\u0430\u0433\u0438\u044f \u043d\u0430\u0447\u0438\u043d\u0430\u0435\u0442\u0441\u044f, \u043a\u043e\u0433\u0434\u0430 \u043c\u044b \u0443\u0447\u0438\u043c \u043c\u0430\u0448\u0438\u043d\u044b \u043c\u044b\u0441\u043b\u0438\u0442\u044c \u0441 \u043d\u0430\u043c\u0438 \u043d\u0430 \u043e\u0434\u043d\u043e\u043c \u044f\u0437\u044b\u043a\u0435.\u00bb","title":"\u041e\u0431 \u0430\u0432\u0442\u043e\u0440\u0435"},{"location":"about/#501447","text":"\u0421\u0442\u0443\u0434\u0435\u043d\u0442 1-\u0433\u043e \u043a\u0443\u0440\u0441\u0430 \u0431\u0430\u043a\u0430\u043b\u0430\u0432\u0440\u0438\u0430\u0442\u0430 \u0423\u043d\u0438\u0432\u0435\u0